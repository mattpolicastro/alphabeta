# ── Local LLM (Ollama) ──────────────────────────────────────────────
# The app works without an LLM — the chat falls back to regex-based
# template routing. Set these to enable multi-turn LLM conversation.

# Ollama server URL (server-side, used by the /api/llm proxy route).
# Default: http://localhost:11434
# If Ollama runs on another machine, point here (e.g. http://mac-studio.local:11434).
OLLAMA_BASE_URL=http://localhost:11434

# Model tag to use for chat and extraction. Must support JSON format output.
# Default: qwen3.6:27b
# Tested models: qwen3.6:27b, qwen3.6:27b-mtp-q8_0
# The model must already be pulled (`ollama pull <model>`).
NEXT_PUBLIC_LLM_MODEL=qwen3.6:27b
